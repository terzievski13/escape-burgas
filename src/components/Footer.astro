---
import { nav, site } from "../config";
const year = new Date().getFullYear();
---

<footer style="background:var(--color-surface); border-top:1px solid var(--color-line);">
  <div class="container-x section-pad-xl">

    <!-- CTA headline -->
    <div style="text-align:center; margin-bottom:54px;">
      <p class="eyebrow" style="margin-bottom:26px;">Готови за приключение?</p>
      <h2 style="font-family:'Cormorant Garamond',serif; font-weight:500; font-size:clamp(2.4rem, 8vw, 6rem); line-height:0.96; margin:0;">
        Резервирайте<br /><em style="font-style:italic;">своето приключение</em>
      </h2>
    </div>

    <!-- Contact info -->
    <div style="margin-bottom:64px; text-align:center;">
      <div class="footer-contact" style="margin-bottom:20px;">
        {site.phones.map((phone) => (
          <a href={`tel:${phone.replace(/\s/g, "")}`} class="link-underline" style="font-family:'Cormorant Garamond',serif; font-size:clamp(2.1rem,6vw,3rem); color:#e6dcc4;">
            {phone}
          </a>
        ))}
      </div>
      <a href={`mailto:${site.email}`} class="link-underline" style="font-family:'EB Garamond',serif; font-size:2.2rem; color:#c4b89a;">
        {site.email}
      </a>
    </div>

    <!-- Locations -->
    <div class="two-col-grid" style="border-top:1px solid var(--color-line); padding-top:40px; margin-bottom:40px;">
      <div>
        <p class="eyebrow" style="margin-bottom:8px;">MAZZE 1</p>
        <a href={site.locationMaps.mazze1} target="_blank" rel="noopener noreferrer" style="font-family:'EB Garamond',serif; font-size:1.5rem; color:var(--color-muted); text-decoration:underline; text-underline-offset:3px; text-decoration-color:currentColor;">{site.locations.mazze1}</a>
      </div>
      <div>
        <p class="eyebrow" style="margin-bottom:8px;">MAZZE 2</p>
        <a href={site.locationMaps.mazze2} target="_blank" rel="noopener noreferrer" style="font-family:'EB Garamond',serif; font-size:1.5rem; color:var(--color-muted); text-decoration:underline; text-underline-offset:3px; text-decoration-color:currentColor;">{site.locations.mazze2}</a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom" style="border-top:1px solid var(--color-line); padding-top:30px;">
      <a href="/" style="font-family:'Cormorant Garamond',serif; font-size:1.8rem; letter-spacing:0.14em; color:#e6dcc4;">Mazze</a>
      <nav style="display:flex; gap:26px; font-family:'EB Garamond',serif; font-size:0.9rem; letter-spacing:0.16em; text-transform:uppercase; color:var(--color-faint);">
        {nav.map((i) => <a href={i.href} class="transition-colors hover:text-[var(--color-paper)]">{i.label}</a>)}
      </nav>
      <p style="font-family:'EB Garamond',serif; font-size:0.9rem; letter-spacing:0.16em; text-transform:uppercase; color:var(--color-faint);">© {year} Mazze Escape Rooms</p>
    </div>

  </div>
</footer>

