---
import { nav, site } from "../config";

interface Props {
  overHero?: boolean;
}
const { overHero = false } = Astro.props;
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header id="site-header" data-over-hero={overHero ? "true" : "false"} class="fixed inset-x-0 top-0 z-50">
  <nav class="container-x flex h-20 items-center justify-between">
    <a href="/" aria-label={site.name} class="relative z-10 block shrink-0" style="font-family:'Cormorant Garamond',serif; font-weight:600; font-size:2.1rem; letter-spacing:0.16em; color:#e6dcc4;">
      Mazze
    </a>

    <ul class="hidden items-center gap-8 md:flex" style="font-family:'EB Garamond',serif; font-size:1rem; letter-spacing:0.14em; text-transform:uppercase;">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                "link-underline py-1 transition-opacity hover:opacity-60",
                isActive(item.href) && "after:w-full",
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="hidden items-center gap-4 md:flex">
      <a href="/kontakti" class="btn btn-ember text-[0.78rem] px-5 py-2.5">
        Резервирай
      </a>
    </div>

    <button
      id="menu-toggle"
      type="button"
      class="relative z-10 flex flex-col items-end justify-center gap-[6px] md:hidden"
      style="width:44px; height:44px; background:transparent; border:none; cursor:pointer; padding:10px 4px;"
      aria-label="Отвори меню"
      aria-expanded="false"
    >
      <span class="bar block h-[2px] w-6 bg-current rounded-sm"></span>
      <span class="bar block h-[2px] w-4 bg-current rounded-sm"></span>
    </button>
  </nav>
</header>

<!-- Mobile menu is a sibling of <header>, not inside it.
     backdrop-filter on the solid header would trap fixed children to the 80px bar. -->
<div id="mobile-menu" aria-hidden="true" style="position:fixed; inset:0; z-index:48; background:#130e09;">
  <div style="padding-top:80px; height:100%; overflow-y:auto;">
    <ul class="container-x" style="padding-top:40px; font-family:'Cormorant Garamond',serif; display:flex; flex-direction:column; gap:4px;">
      {
        nav.map((item) => (
          <li>
            <a href={item.href} class="block" style="font-size:2.75rem; font-weight:600; color:#e6dcc4; padding:10px 0; border-bottom:1px solid rgba(197,56,44,0.12); text-decoration:none;">
              {item.label}
            </a>
          </li>
        ))
      }
      <li style="margin-top:28px;">
        <a href="/kontakti" class="btn btn-ember" style="display:inline-flex;">Резервирай</a>
      </li>
    </ul>
    <div class="container-x" style="margin-top:40px; padding-top:24px; border-top:1px solid rgba(197,56,44,0.2);">
      <p style="font-family:'EB Garamond',serif; font-size:0.72rem; letter-spacing:0.24em; text-transform:uppercase; color:#8f8366; margin:0 0 8px;">Контакт</p>
      <a href={`mailto:${site.email}`} class="link-underline" style="font-family:'EB Garamond',serif; font-size:1rem; color:#c4b89a;">
        {site.email}
      </a>
    </div>
  </div>
</div>

<script>
  const header = document.getElementById("site-header");
  const toggle = document.getElementById("menu-toggle");
  const menu   = document.getElementById("mobile-menu");
  let menuOpen = false;

  const syncSolid = (): void => {
    if (!header) return;
    header.classList.toggle("is-solid", menuOpen || window.scrollY > 24);
  };

  const setMenu = (open: boolean): void => {
    menuOpen = open;
    menu?.classList.toggle("open", open);
    menu?.setAttribute("aria-hidden", String(!open));
    toggle?.classList.toggle("is-open", open);
    toggle?.setAttribute("aria-expanded", String(open));
    toggle?.setAttribute("aria-label", open ? "Затвори меню" : "Отвори меню");
    document.body.style.overflow = open ? "hidden" : "";
    syncSolid();
  };

  syncSolid();
  window.addEventListener("scroll", syncSolid, { passive: true });
  toggle?.addEventListener("click", () => setMenu(!menuOpen));
  menu?.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setMenu(false)));
  window.addEventListener("resize", () => {
    if (window.innerWidth >= 768 && menuOpen) setMenu(false);
  });
</script>
