---
---

<section style="position:relative; height:92vh; min-height:760px; overflow:hidden; background:#130e09;">

  <!-- Background image with warm sepia treatment -->
  <img
    src="https://escapeburgas.com/wp-content/uploads/2022/05/DSC_0178-1.jpg"
    alt="Escape room стая"
    fetchpriority="high"
    decoding="async"
    style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; filter:sepia(0.32) contrast(1.04) brightness(0.66) saturate(1.05);"
  />

  <!-- Dark gradient overlay -->
  <div style="position:absolute; inset:0; background:linear-gradient(to bottom, rgba(19,14,9,0.74) 0%, rgba(19,14,9,0.28) 36%, rgba(19,14,9,0.52) 66%, rgba(19,14,9,0.97) 100%);"></div>

  <!-- Crimson radial glow -->
  <div style="position:absolute; inset:0; background:radial-gradient(ellipse 66% 52% at 50% 44%, rgba(197,56,44,0.12) 0%, transparent 64%);"></div>

  <!-- Horizontal divider line below header -->
  <div style="position:absolute; top:90px; left:52px; right:52px; height:1px; background:linear-gradient(to right, transparent, rgba(197,56,44,0.55), transparent); z-index:30;"></div>

  <!-- Ornamental frame rectangle -->
  <div style="position:absolute; left:52px; right:52px; bottom:56px; top:120px; border:1px solid rgba(197,56,44,0.24); pointer-events:none; z-index:10;"></div>

  <!-- Corner brackets -->
  <div style="position:absolute; left:44px; top:112px; width:16px; height:16px; border-top:1px solid #c5382c; border-left:1px solid #c5382c; z-index:10;"></div>
  <div style="position:absolute; right:44px; top:112px; width:16px; height:16px; border-top:1px solid #c5382c; border-right:1px solid #c5382c; z-index:10;"></div>
  <div style="position:absolute; left:44px; bottom:48px; width:16px; height:16px; border-bottom:1px solid #c5382c; border-left:1px solid #c5382c; z-index:10;"></div>
  <div style="position:absolute; right:44px; bottom:48px; width:16px; height:16px; border-bottom:1px solid #c5382c; border-right:1px solid #c5382c; z-index:10;"></div>

  <!-- Centered hero content -->
  <div style="position:absolute; inset:0; z-index:20; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:0 80px;">

    <p style="font-family:'EB Garamond',serif; font-size:0.78rem; letter-spacing:0.42em; text-transform:uppercase; color:#d4655a; margin:0 0 22px;">
      · Бургас · Пет стаи за бягство ·
    </p>

    <h1 style="font-family:'Cormorant Garamond',serif; font-weight:500; font-size:clamp(4.5rem, 10vw, 8rem); line-height:0.92; letter-spacing:0.01em; margin:0;">
      Живей<br />
      <em style="font-style:italic; color:#c5382c;">приключението</em>
    </h1>

    <p style="font-family:'EB Garamond',serif; font-size:1.15rem; line-height:1.6; color:#c4b89a; max-width:520px; margin:34px 0 0;">
      Логика, интуиция и екипна работа. Всеки механизъм е изработен на ръка — влезте и намерете пътя си навън.
    </p>

    <div style="display:flex; gap:18px; margin-top:38px; flex-wrap:wrap; justify-content:center;">
      <a href="/stai" class="btn btn-solid">Разгледай стаите</a>
      <a href="/kontakti" class="btn btn-outline">Резервирай</a>
    </div>

  </div>

</section>
