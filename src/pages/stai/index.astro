---
import Base from "../../layouts/Base.astro";
import PageHeader from "../../components/PageHeader.astro";
import { site } from "../../config";
import { rooms } from "../../data/rooms";

const mazze1 = rooms.filter((r) => r.location === "mazze1");
const mazze2 = rooms.filter((r) => r.location === "mazze2");
---

<Base
  title={`Стаи — ${site.name}`}
  description="5 escape room стаи в Бургас — Египет, пътуване във времето, мистерии и африканска магия."
>
  <PageHeader
    eyebrow="Стаи"
    title="Изберете стая"
    intro="Пет различни свята, всеки с уникална история. Намерете стаята, която ви предизвиква."
  />

  <!-- MAZZE 1 -->
  <section class="container-x" style="padding-top:90px; padding-bottom:40px;">

    <!-- Section header -->
    <div class="rooms-section-header reveal" style="display:flex; align-items:center; gap:20px; margin-bottom:48px;">
      <span style="font-family:'Cormorant Garamond',serif; font-style:italic; font-weight:500; font-size:clamp(1.8rem,3vw,2.5rem); color:#e6dcc4; white-space:nowrap;">Mazze 1</span>
      <span style="flex:1; height:1px; background:rgba(197,56,44,0.3);"></span>
      <span style="font-family:'EB Garamond',serif; font-size:clamp(0.82rem,2vw,1.35rem); letter-spacing:0.16em; text-transform:uppercase; color:#8f8366; white-space:nowrap;">{site.locations.mazze1.split(",")[0]} · {mazze1.length} стаи</span>
    </div>

    <!-- 2-column card grid -->
    <div class="rooms-listing-grid">
      {mazze1.map((room, i) => (
        <a
          href={`/stai/${room.slug}`}
          class="reveal rooms-listing-card"
          style={`transition-delay:${i * 90}ms`}
        >
          <div style="position:relative; aspect-ratio:16/9; overflow:hidden;">
            <img
              src={room.cover}
              alt={room.name}
              loading="lazy"
              decoding="async"
              style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; filter:sepia(0.26) brightness(0.86) saturate(1.04); transition:transform 0.7s ease;"
              class="rooms-listing-img"
            />
          </div>
          <div style="padding:34px 34px 36px; display:flex; flex-direction:column; flex:1;">
            <h3 style="font-family:'Cormorant Garamond',serif; font-weight:600; font-size:clamp(1.8rem,2.8vw,2.5rem); margin:0; line-height:1.1;">{room.name}</h3>
            <p style="font-family:'EB Garamond',serif; font-size:1rem; line-height:1.6; color:#a99d80; margin:14px 0 0;">{room.description}</p>
            <div style="display:flex; align-items:center; gap:12px; font-family:'EB Garamond',serif; font-size:1rem; color:#b3a382; margin:22px 0; padding:16px 0; border-top:1px dashed rgba(197,56,44,0.34); border-bottom:1px dashed rgba(197,56,44,0.34);">
              <span>{room.duration} мин</span>
              <span style="color:#c5382c;">◆</span>
              <span>{room.players} играчи</span>
              <span style="color:#c5382c;">◆</span>
              <span>{room.minAge}+</span>
            </div>
            <div style="margin-top:auto; font-family:'EB Garamond',serif; font-size:0.9rem; letter-spacing:0.14em; text-transform:uppercase; color:#c5382c;">Виж стаята →</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- MAZZE 2 -->
  <section class="container-x" style="padding-top:50px; padding-bottom:110px;">

    <!-- Section header -->
    <div class="rooms-section-header reveal" style="display:flex; align-items:center; gap:20px; margin-bottom:48px;">
      <span style="font-family:'Cormorant Garamond',serif; font-style:italic; font-weight:500; font-size:clamp(1.8rem,3vw,2.5rem); color:#e6dcc4; white-space:nowrap;">Mazze 2</span>
      <span style="flex:1; height:1px; background:rgba(197,56,44,0.3);"></span>
      <span style="font-family:'EB Garamond',serif; font-size:clamp(0.82rem,2vw,1.35rem); letter-spacing:0.16em; text-transform:uppercase; color:#8f8366; white-space:nowrap;">{site.locations.mazze2.split(",")[0]} · {mazze2.length} стая</span>
    </div>

    <!-- Horizontal featured card -->
    {mazze2.map((room) => (
      <a
        href={`/stai/${room.slug}`}
        class="reveal rooms-featured-card"
      >
        <div class="rooms-featured-img">
          <img
            src={room.cover}
            alt={room.name}
            loading="lazy"
            decoding="async"
            style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; filter:sepia(0.26) brightness(0.86) saturate(1.04); transition:transform 0.7s ease;"
            class="rooms-listing-img"
          />
        </div>
        <div class="rooms-featured-body">
          <div style="font-family:'EB Garamond',serif; font-size:clamp(0.82rem,2vw,1.35rem); letter-spacing:0.26em; text-transform:uppercase; color:#c5382c; margin-bottom:14px;">Африканска магия</div>
          <h3 style="font-family:'Cormorant Garamond',serif; font-weight:600; font-size:clamp(2rem,4vw,3.375rem); line-height:0.98; margin:0;">{room.name}</h3>
          <p style="font-family:'EB Garamond',serif; font-size:1.05rem; line-height:1.65; color:#a99d80; margin:18px 0 0;">{room.description}</p>
          <div style="display:flex; align-items:center; gap:12px; font-family:'EB Garamond',serif; font-size:1rem; color:#b3a382; margin:24px 0; padding:16px 0; border-top:1px dashed rgba(197,56,44,0.34); border-bottom:1px dashed rgba(197,56,44,0.34);">
            <span>{room.duration} мин</span>
            <span style="color:#c5382c;">◆</span>
            <span>{room.players} играчи</span>
            <span style="color:#c5382c;">◆</span>
            <span>{room.minAge}+</span>
          </div>
          <div style="font-family:'EB Garamond',serif; font-size:0.9rem; letter-spacing:0.14em; text-transform:uppercase; color:#c5382c;">Виж стаята →</div>
        </div>
      </a>
    ))}
  </section>
</Base>

<style>
  /* 2-col card grid */
  .rooms-listing-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  /* Standard card */
  .rooms-listing-card {
    background: #1b130c;
    border: 1px solid rgba(197,56,44,0.3);
    border-radius: 2px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    color: #e6dcc4;
    text-decoration: none;
  }
  .rooms-listing-card:hover .rooms-listing-img {
    transform: scale(1.04);
  }

  /* Horizontal featured card (MAZZE 2) */
  .rooms-featured-card {
    background: #1b130c;
    border: 1px solid rgba(197,56,44,0.3);
    border-radius: 2px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    color: #e6dcc4;
    text-decoration: none;
  }
  .rooms-featured-card:hover .rooms-listing-img {
    transform: scale(1.04);
  }
  .rooms-featured-img {
    position: relative;
    overflow: hidden;
    min-height: 380px;
  }
  .rooms-featured-body {
    padding: 56px 52px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* Mobile */
  @media (max-width: 767px) {
    .rooms-listing-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .rooms-featured-card {
      grid-template-columns: 1fr;
    }
    .rooms-featured-img {
      min-height: 240px;
    }
    .rooms-featured-body {
      padding: 28px 24px 32px;
    }
    .rooms-section-header {
      flex-wrap: wrap;
      gap: 10px;
    }
    .rooms-section-header span:nth-child(2) {
      display: none;
    }
  }

  /* Tablet */
  @media (min-width: 768px) and (max-width: 1023px) {
    .rooms-listing-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .rooms-featured-card {
      grid-template-columns: 1fr;
    }
    .rooms-featured-img {
      min-height: 300px;
    }
    .rooms-featured-body {
      padding: 36px 36px 40px;
    }
  }
</style>
