---
import Base from "../layouts/Base.astro";
import { site } from "../config";
---

<Base title={`404 — ${site.name}`} description="Страницата не е намерена.">
  <section class="container-x flex min-h-[72vh] flex-col justify-center py-40">
    <p class="eyebrow">Грешка 404</p>
    <h1 class="mt-4 text-6xl leading-[0.95] md:text-8xl">
      Стаята<br />не съществува.
    </h1>
    <p class="mt-7 max-w-md text-lg text-[var(--color-muted)]">
      Тази страница не е намерена или е преместена. Ще ви върнем обратно в играта.
    </p>
    <div class="mt-9 flex flex-wrap gap-4">
      <a href="/" class="btn btn-ember">Начало</a>
      <a href="/stai" class="btn btn-outline">Разгледай стаите</a>
    </div>
  </section>
</Base>
